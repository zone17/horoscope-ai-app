{
  "name": "horoscope-philosophy-mcp",
  "version": "2.1.0",
  "type": "module",
  "description": "MCP server for daily philosophical horoscope guidance via gettodayshoroscope.com",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "horoscope-philosophy-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run build:apps",
    "build:server": "tsc",
    "build:apps": "npm run build:app:share-card && npm run build:app:philosopher-picker",
    "build:app": "vite build",
    "build:app:share-card": "MCP_APP=share-card vite build",
    "build:app:philosopher-picker": "MCP_APP=philosopher-picker vite build",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "echo 'No tests yet'"
  },
  "keywords": [
    "mcp",
    "horoscope",
    "philosophy",
    "zodiac",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@horoscope/shared": "*",
    "@modelcontextprotocol/ext-apps": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
